# Resolve session identifier: UUID, friendly name, or list number
# Returns the actual session UUID, or undef if not found
sub _resolve_session_id {
    my ($identifier, $debug) = @_;
    
    my $sessions_dir = CLIO::Util::PathResolver::get_sessions_dir();
    return undef unless -d $sessions_dir;
    
    opendir(my $dh, $sessions_dir) or return undef;
    my @json_files = grep { /\.json$/ } readdir($dh);
    closedir($dh);
    
    # Build session list sorted by mtime (for list number resolution)
    my @sessions;
    for my $json_file (@json_files) {
        my $sid = $json_file;
        $sid =~ s/\.json$//;
        my $file_path = "$sessions_dir/$json_file";
        my @stat = stat($file_path);
        my $mtime = $stat[9] // 0;
        
        # Read session name from file
        my $name = undef;
        eval {
            open my $fh, '<', $file_path or die;
            local $/;
            my $json = <$fh>;
            close $fh;
            my $data = decode_json($json);
            $name = $data->{session_name} if $data->{session_name};
        };
        
        push @sessions, { id => $sid, name => $name, mtime => $mtime };
    }
    
    @sessions = sort { $b->{mtime} <=> $a->{mtime} } @sessions;
    
    # 1. Exact UUID match
    for my $s (@sessions) {
        return $s->{id} if $s->{id} eq $identifier;
    }
    
    # 2. UUID prefix match
    my @uuid_matches = grep { index($_->{id}, $identifier) == 0 } @sessions;
    if (@uuid_matches == 1) {
        print STDERR "[DEBUG] Resolved UUID prefix '$identifier' -> $uuid_matches[0]->{id}\n" if $debug;
        return $uuid_matches[0]->{id};
    }
    
    # 3. List number (from --sessions output)
    if ($identifier =~ /^\d+$/) {
        my $idx = $identifier - 1;
        if ($idx >= 0 && $idx < @sessions) {
            print STDERR "[DEBUG] Resolved list number $identifier -> $sessions[$idx]->{id}\n" if $debug;
            return $sessions[$idx]->{id};
        }
    }
    
    # 4. Exact friendly name match (case-insensitive)
    for my $s (@sessions) {
        next unless $s->{name};
        if (lc($s->{name}) eq lc($identifier)) {
            print STDERR "[DEBUG] Resolved name '$identifier' -> $s->{id}\n" if $debug;
            return $s->{id};
        }
    }
    
    # 5. Friendly name prefix match (case-insensitive)
    my $lc_id = lc($identifier);
    my @name_matches = grep { $_->{name} && index(lc($_->{name}), $lc_id) == 0 } @sessions;
    if (@name_matches == 1) {
        print STDERR "[DEBUG] Resolved name prefix '$identifier' -> $name_matches[0]->{id}\n" if $debug;
        return $name_matches[0]->{id};
    }
    
    # 6. Friendly name substring match (case-insensitive)
    my @substr_matches = grep { $_->{name} && index(lc($_->{name}), $lc_id) >= 0 } @sessions;
    if (@substr_matches == 1) {
        print STDERR "[DEBUG] Resolved name substring '$identifier' -> $substr_matches[0]->{id}\n" if $debug;
        return $substr_matches[0]->{id};
    }
    
    # Multiple matches - report ambiguity
    if (@uuid_matches > 1 || @name_matches > 1 || @substr_matches > 1) {
        my @all_matches = @uuid_matches > 1 ? @uuid_matches : @name_matches > 1 ? @name_matches : @substr_matches;
        print "[WARN] Ambiguous session identifier '$identifier'. Matches:\n";
        for my $m (@all_matches) {
            my $display = $m->{name} || $m->{id};
            printf "  - %s (%s)\n", $display, substr($m->{id}, 0, 12);
        }
        return undef;
    }
    
    return undef;
}

# Helper function for --sessions CLI display
sub _format_relative_time_cli {
    my ($timestamp) = @_;
    return 'unknown' unless $timestamp;
    my $now = time();
    my $diff = $now - $timestamp;
    if ($diff < 60) {
        return "just now";
    } elsif ($diff < 3600) {
        my $mins = int($diff / 60);
        return "$mins min ago";
    } elsif ($diff < 86400) {
        my $hours = int($diff / 3600);
        return "$hours hr ago";
    } elsif ($diff < 604800) {
        my $days = int($diff / 86400);
        return "$days day" . ($days > 1 ? "s" : "") . " ago";
    } else {
        my @t = localtime($timestamp);
        return sprintf("%04d-%02d-%02d", $t[5]+1900, $t[4]+1, $t[3]);
    }
}

sub _fetch_models_for_provider {
    my ($provider_name, $provider_def, $api_key, $config) = @_;

    my $models = [];

    if ($provider_name eq 'github_copilot') {
        eval {
            require CLIO::Core::GitHubCopilotModelsAPI;
            my $models_api = CLIO::Core::GitHubCopilotModelsAPI->new(
                debug   => 0,
                api_key => $api_key,
            );
            my $data = $models_api->fetch_models();
            $models = $data->{data} || [] if $data;
        };
    } elsif ($provider_def->{native_api} && $provider_name eq 'google') {
        my $api_base = $provider_def->{api_base} || 'https://generativelanguage.googleapis.com/v1beta';
        $api_base =~ s{/+$}{};
        my $models_url = "$api_base/models?key=$api_key";
        eval {
            require CLIO::Compat::HTTP;
            my $ua = CLIO::Compat::HTTP->new(timeout => 15);
            my $resp = $ua->get($models_url, headers => { 'Accept' => 'application/json' });
            if ($resp->is_success) {
                my $data = CLIO::Util::JSON::decode_json($resp->decoded_content);
                for my $m (@{$data->{models} || []}) {
                    my @methods = @{$m->{supportedGenerationMethods} || []};
                    next unless grep { $_ eq 'generateContent' } @methods;
                    (my $model_id = $m->{name}) =~ s{^models/}{};
                    push @$models, {
                        id          => $model_id,
                        name        => $m->{displayName} || $model_id,
                        description => $m->{description} || '',
                    };
                }
            }
        };
    } elsif ($provider_name =~ /^minimax/) {
        $models = [
            { id => 'MiniMax-M2.7',          name => 'MiniMax M2.7',          description => 'Recursive self-improvement, ~60 tps' },
            { id => 'MiniMax-M2.7-highspeed', name => 'MiniMax M2.7 Highspeed', description => 'Same as M2.7, ~100 tps' },
            { id => 'MiniMax-M2.5',          name => 'MiniMax M2.5',          description => 'Code generation and refactoring, ~60 tps' },
            { id => 'MiniMax-M2.5-highspeed', name => 'MiniMax M2.5 Highspeed', description => 'Same as M2.5, ~100 tps' },
            { id => 'MiniMax-M2.1',          name => 'MiniMax M2.1',          description => '230B params, code + reasoning, ~60 tps' },
            { id => 'MiniMax-M2.1-highspeed', name => 'MiniMax M2.1 Highspeed', description => 'Same as M2.1, ~100 tps' },
            { id => 'MiniMax-M2',            name => 'MiniMax M2',            description => 'Function calling, advanced reasoning' },
        ];
    } else {
        my $api_base = $provider_def->{api_base} || '';
        my $models_url;
        if ($api_base =~ m{openrouter\.ai}i) {
            $models_url = 'https://openrouter.ai/api/v1/models';
        } elsif ($api_base =~ m{^(https?://[^/]+)}) {
            $models_url = "$1/v1/models";
        }
        return [] unless $models_url && $api_key;
        eval {
            require CLIO::Compat::HTTP;
            my $ua = CLIO::Compat::HTTP->new(timeout => 15);
            my %headers = ('Authorization' => "Bearer $api_key");
            my $resp = $ua->get($models_url, headers => \%headers);
            if ($resp->is_success) {
                my $data = CLIO::Util::JSON::decode_json($resp->decoded_content);
                $models = $data->{data} || [];
            }
        };
    }

    return $models;
}

exit 0;
